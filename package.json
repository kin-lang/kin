{
  "name": "@kin-lang/kin",
  "version": "0.4.3",
  "description": "Kin Programming Language: write computer programs in Kinyarwanda.",
  "main": "./dist/src/index.js",
  "bin": "./dist/bin/kin.js",
  "author": "MURANGWA Pacifique",
  "license": "MIT",
  "private": false,
  "homepage": "https://github.com/kin-lang/kin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kin-lang/kin.git"
  },
  "bugs": {
    "url": "https://github.com/kin-lang/kin/issues"
  },
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint . --fix",
    "build": "tsc",
    "build:exe": "npm run build && pkg dist/bin/kin.js --targets node18-win-x64 --output release/kin-win-x64.exe",
    "build:exe:all": "npm run build && pkg dist/bin/kin.js --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --out-path release",
    "test": "vitest --no-watch",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "bin-script": "ts-node ./bin/kin.ts"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "dist/package.json"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "release"
  },
  "keywords": [
    "kin",
    "language",
    "kinyarwanda",
    "interpreter"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/prompt-sync": "^4.2.3",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "husky": "^9.0.10",
    "pkg": "^5.8.1",
    "prettier": "^3.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "moment": "^2.30.1",
    "prompt-sync": "^4.2.0"
  }
}
